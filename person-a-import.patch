+
+
+# ─── HAUPTPROGRAMM ───────────────────────────────────────────────────────────
+async def main():
+    print(f"\n{BOLD}{BLUE}{'═'*65}")
+    print(f"  🔍  ORACLE LAG MONITOR  —  PHASE 1")
+    print(f"  Chainlink BTC/USD (Polygon) vs. Binance Spot")
